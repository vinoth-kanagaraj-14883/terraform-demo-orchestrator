# ── AWS Credentials ──
AWS_ACCESS_KEY_ID=AKIA...your-key...
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1

# ── Azure (if using azure provider) ──
# ARM_CLIENT_ID=...
# ARM_CLIENT_SECRET=...
# ARM_SUBSCRIPTION_ID=...
# ARM_TENANT_ID=...

# ── Site24x7 OAuth (for APM monitor group + chaos agent) ──
SITE24X7_CLIENT_ID=your-zoho-oauth-client-id
SITE24X7_CLIENT_SECRET=your-zoho-oauth-client-secret
SITE24X7_REFRESH_TOKEN=your-zoho-oauth-refresh-token
